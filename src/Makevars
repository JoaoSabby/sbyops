# Flags de compilação do pacote sbyops.
#
# OpenMP é usado para paralelizar a análise por colunas.
# As macros SHLIB_OPENMP_* são fornecidas pelo próprio R.
#
# Observações de portabilidade:
# - Não forçamos níveis de otimização no pacote (ex.: -O3) para evitar
#   warnings de portabilidade em R CMD check --as-cran.
# - Perfis agressivos de compilação devem ser ativados apenas em ambientes
#   controlados (ex.: via Makevars.site/Makevars.user).

# Do not propagate R's OpenMP Fortran flag here. Some tuned R builds mix
# Intel C/C++ with GNU Fortran and expose an Intel-only flag such as -qopenmp
# through SHLIB_OPENMP_FFLAGS, which makes gfortran fail before package code is
# compiled. The Fortran backend keeps OpenMP directives as comments when the
# compiler is not explicitly opened with an OpenMP flag, while the C backend can
# still use R's C OpenMP flags when available.
PKG_FFLAGS =
PKG_CFLAGS = $(SHLIB_OPENMP_CFLAGS)
PKG_CXXFLAGS = $(SHLIB_OPENMP_CFLAGS)
PKG_LIBS   = $(SHLIB_OPENMP_CFLAGS) $(FLIBS)
