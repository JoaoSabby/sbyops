# Flags de compilação do pacote sbyops.
#
# Este pacote é implantado em ambiente HPC dedicado do cliente com Intel oneMKL
# e CPUs AVX-512. A configuração abaixo força o caminho oneMKL single precision
# para kernels densos e mantém OpenMP habilitado para os trechos pareados.

PKG_FFLAGS = $(SHLIB_OPENMP_FFLAGS) -mavx512f -mavx512dq -mavx512bw -mavx512vl -mfma
PKG_CPPFLAGS = -I$(MKLROOT)/include
PKG_CFLAGS = $(SHLIB_OPENMP_CFLAGS) -mavx512f -mavx512dq -mavx512bw -mavx512vl -mfma
PKG_CXXFLAGS = $(SHLIB_OPENMP_CFLAGS) -mavx512f -mavx512dq -mavx512bw -mavx512vl -mfma
PKG_LIBS = -L$(MKLROOT)/lib/intel64 -Wl,--no-as-needed -lmkl_gf_lp64 -lmkl_gnu_thread -lmkl_core -lgomp -lpthread -lm -ldl $(FLIBS)
